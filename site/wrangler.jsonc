{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pebble",
  "compatibility_date": "2026-04-27",
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "none"
  }
}
